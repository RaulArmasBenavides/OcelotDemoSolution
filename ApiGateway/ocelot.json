{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/Account",
      "UpstreamHttpMethod": [ "Post" ],
      "DownstreamScheme": "http",
      "ServiceName": "authentication-service",
      "DownstreamPathTemplate": "/api/Account",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      }
    },
    {
      "UpstreamPathTemplate": "/api/Customer",
      "UpstreamHttpMethod": [ "Get", "Post", "Put" ],
      "DownstreamScheme": "http",
      "ServiceName": "customer-service",
      "DownstreamPathTemplate": "/api/Customer",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      }
    },
    {
      "UpstreamPathTemplate": "/api/Customer/{customerId}",
      "UpstreamHttpMethod": [ "Get", "Delete" ],
      "DownstreamScheme": "http",
      "ServiceName": "customer-service",
      "DownstreamPathTemplate": "/api/Customer/{customerId}",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      }
    },
    {
      "UpstreamPathTemplate": "/api/Product",
      "UpstreamHttpMethod": [ "Get", "Post", "Put" ],
      "DownstreamScheme": "http",
      "ServiceName": "product-service",
      "DownstreamPathTemplate": "/api/Product",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      },
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RouteClaimsRequirement": {
        "Role": "Administrator"
      }
    },
    {
      "UpstreamPathTemplate": "/api/Product/{productId}",
      "UpstreamHttpMethod": [ "Get", "Delete" ],
      "DownstreamScheme": "http",
      "ServiceName": "product-service",
      "DownstreamPathTemplate": "/api/Product/{productId}",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      }
    },
    {
      "UpstreamPathTemplate": "/api/Order",
      "UpstreamHttpMethod": [ "Get", "Post", "Put" ],
      "DownstreamScheme": "http",
      "ServiceName": "order-service",
      "DownstreamPathTemplate": "/api/Order",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      },
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "60s",
        "PeriodTimespan": 60,
        "Limit": 1
      }
    },
    {
      "UpstreamPathTemplate": "/api/Order/{orderId}",
      "UpstreamHttpMethod": [ "Get", "Delete" ],
      "DownstreamScheme": "http",
      "ServiceName": "order-service",
      "DownstreamPathTemplate": "/api/Order/{orderId}",
      "UseServiceDiscovery": true,
      "LoadBalancerOptions": {
        "Type": "RoundRobin"
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:8001",
    "ServiceDiscoveryProvider": {
      "Type": "Consul",
      "Host": "consul",
      "Port": 8500
    },
    "RateLimitOptions": {
      "QuotaExceededMessage": "Request not allowed",
      "HttpStatusCode": 909
    }
  }
}
